<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>CampusMarket</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Fonte padrão -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

  <!-- Fonte da marca -->
  <link href="https://fonts.googleapis.com/css2?family=Pacifico&display=swap" rel="stylesheet">

  <style>
    body {
      font-family: 'Poppins', sans-serif;
    }
    .navbar-custom {
      background: #fff;
      padding: 15px 30px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .logo {
      font-family: 'Pacifico', cursive;
      font-size: 24px;
      color: #2c7be5;
    }
    .btn-login {
      background: #2c7be5;
      color: #fff;
      border: none;
      padding: 8px 20px;
    }
    .hero {
      height: 80vh;
      background: linear-gradient(to right, rgba(0,0,0,0.8), rgba(0,0,0,0.2)),
                  url('/images/banner.jpg') center/cover no-repeat;
      color: white;
      display: flex;
      align-items: center;
      padding: 50px;
    }

    .hero h1 {
      font-size: 48px;
      font-weight: 700;
    }

    .cliente-nome {
      font-size: 18px;
      margin-top: 10px;
      color: #ddd;
    }

    .btn-white {
      background: #fff;
      border: none;
      margin-right: 10px;
    }

    /* VENDEDORES */
    .vendedores {
      padding: 40px;
      background: #f8f9fa;
    }

    .card-vendedor {
      border: none;
      border-radius: 15px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
      padding: 20px;
      text-align: center;
    }

    .card-vendedor h5 {
      margin-top: 10px;
    }

    .status-online {
      color: green;
      font-weight: bold;
    }

    /* BANNERS */
    .banners img {
      width: 100%;
      border-radius: 10px;
    }

    /* APP */
    .app-section {
      background: #2c7be5;
      padding: 60px;
      border-radius: 20px;
      margin: 50px;
      color: #fff;
    }
  </style>
</head>

<body>

  <!-- NAVBAR -->
  <nav class="navbar navbar-custom d-flex justify-content-between">
    <div class="logo">CampusMarket</div>

    <div>
      <span>Olá, <strong><%= cliente.nome %></strong></span>
      <a href="/logout" class="btn btn-login ms-3">Sair</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div>
      <h1>O que você quer comprar hoje?</h1>
      <p class="cliente-nome">Bem-vindo, <%= cliente.nome %> 👋</p>

      <div class="mt-3">
        <button class="btn btn-white">🛒 Ver Produtos</button>
        <button class="btn btn-white">📦 Meus Pedidos</button>
      </div>
    </div>
  </section>

  <!-- VENDEDORES -->
  <section class="vendedores container">
    <h2 class="mb-4 text-center">Vendedores disponíveis</h2>

    <div class="row">
      <% vendedores.forEach(vendedor => { %>
        <div class="col-md-3 mb-4">
          <div class="card-vendedor">
            <img src="/images/user.png" width="80">
            <h5><%= vendedor.nome %></h5>
            <p class="status-online">● Online</p>
            <button class="btn btn-primary btn-sm">Ver Loja</button>
          </div>
        </div>
      <% }) %>
    </div>
  </section>

  <!-- BANNERS -->
  <section class="container my-5 banners">
    <div class="row g-3">
      <div class="col-md-4">
        <img src="/images/banner1.jpg">
      </div>
      <div class="col-md-4">
        <img src="/images/banner2.jpg">
      </div>
      <div class="col-md-4">
        <img src="/images/banner3.jpg">
      </div>
    </div>
  </section>

  <!-- APP -->
  <section class="app-section container">
    <div class="row align-items-center">
      <div class="col-md-6">
        <h2>CampusMarket App</h2>
        <p>Compre produtos dentro do campus de forma rápida e fácil.</p>
      </div>

      <div class="col-md-6 text-center">
        <img src="/images/app.png" width="250">
      </div>
    </div>
  </section>

</body>
</html>