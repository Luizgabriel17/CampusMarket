<!DOCTYPE html>
<html>
<head>
  <title>Cliente</title>

  <link rel="stylesheet" href="/css/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<%- include('partials/header') %>
<%- include('partials/carrinho') %>

<div class="content">

<h2>🍔 Produtos</h2>

<!-- BUSCA -->
<input type="text" id="search" class="form-control search-box" placeholder="Buscar produto...">

<!-- FILTRO -->
<select id="filtro" class="form-control mb-3">
  <option value="">Todos vendedores</option>
  <% vendedores.forEach(v => { %>
    <option value="<%= v.nome %>"><%= v.nome %></option>
  <% }) %>
</select>

<div class="row" id="lista">

<% produtos.forEach(p => { %>

  <div class="col-md-4 mb-3 produto"
       data-nome="<%= p.nome %>"
       data-vendedor="<%= p.vendedor_nome %>">

    <div class="card p-3 card-produto">

      <h5><%= p.nome %></h5>

      <p class="text-muted">👨‍🍳 <%= p.vendedor_nome %></p>

      <p><%= p.descricao %></p>

      <p><strong>R$ <%= p.preco %></strong></p>

      <!-- AVALIAÇÃO -->
      <p>⭐ <%= p.media_avaliacao || "Sem avaliações" %></p>

      <form action="/carrinho/add" method="POST">
        <input type="hidden" name="id" value="<%= p.id %>">
        <input type="hidden" name="nome" value="<%= p.nome %>">
        <input type="hidden" name="preco" value="<%= p.preco %>">
        <input type="hidden" name="vendedor_id" value="<%= p.vendedor_id %>">

        <button class="btn btn-primary w-100">
          🛒 Adicionar
        </button>
      </form>

    </div>
  </div>

<% }) %>

</div>

</div>

<!-- JS FILTRO -->
<script>
const search = document.getElementById("search");
const filtro = document.getElementById("filtro");

search.addEventListener("keyup", filtrar);
filtro.addEventListener("change", filtrar);

function filtrar(){
  const texto = search.value.toLowerCase();
  const vend = filtro.value;

  document.querySelectorAll(".produto").forEach(el => {
    const nome = el.dataset.nome.toLowerCase();
    const vendedor = el.dataset.vendedor;

    const okNome = nome.includes(texto);
    const okVend = !vend || vendedor === vend;

    el.style.display = (okNome && okVend) ? "block" : "none";
  });
}
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<%- include('partials/footer') %>
</body>
</html>