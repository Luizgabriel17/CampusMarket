<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<nav class="navbar navbar-dark bg-dark">
  <div class="container">
    <span class="navbar-brand">CampusMarket - Vendedor</span>
    <div>
      <span class="text-white me-3">Olá, <%= user.nome %></span>
      <a href="/logout" class="btn btn-light">Sair</a>
    </div>
  </div>
</nav>

<div class="container mt-4">
  <h3>Painel do Vendedor 🧑‍💼</h3>

  <div class="row mt-4">

    <div class="col-md-4">
      <div class="card p-3 shadow">
        <h5>📦 Produtos</h5>
        <p>Gerencie seus produtos</p>
        <a href="/dashboard/produtos" class="btn btn-primary">Acessar</a>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card p-3 shadow">
        <h5>🛒 Pedidos</h5>
        <p>Veja os pedidos recebidos</p>
        <a href="/dashboard/pedidos" class="btn btn-primary">Ver pedidos</a>
      </div>
    </div>

  </div>
</div>

</body>
</html>