<!DOCTYPE html>
<html>
<head>
  <title>Novo Produto</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="container mt-5">

  <h2>➕ Cadastrar Produto</h2>

  <form action="/dashboard/novo" method="POST">

    <input class="form-control mb-3" type="text" name="nome" placeholder="Nome" required>

    <input class="form-control mb-3" type="number" step="0.01" name="preco" placeholder="Preço" required>

    <input class="form-control mb-3" type="text" name="imagem_url" placeholder="URL da imagem">

    <textarea class="form-control mb-3" name="descricao" placeholder="Descrição"></textarea>

    <button class="btn btn-danger">Cadastrar</button>

  </form>

</body>
</html>