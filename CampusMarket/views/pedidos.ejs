<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Pedidos - CampusMarket</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Inter',sans-serif;}

body{
  background:#ffffff;
  display:flex;
}

/* SIDEBAR */
.sidebar{
  width:220px;
  height:100vh;
  background:#f8f8f8;
  padding:20px;
  position:fixed;
}

/* CONTENT */
.content{
  margin-left:240px;
  padding:30px;
  width:100%;
}

/* TITLE */
.title{
  font-size:1.8rem;
  font-weight:800;
  margin-bottom:20px;
}

/* GRID */
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(320px,1fr));
  gap:20px;
}

/* CARD */
.card-pedido{
  background:#fff;
  border-radius:16px;
  padding:20px;
  box-shadow:0 10px 30px rgba(0,0,0,0.08);
  animation:fadeUp 0.6s ease;
  transition:.3s;
}

.card-pedido:hover{
  transform:translateY(-5px);
}

/* HEADER */
.card-header{
  display:flex;
  justify-content:space-between;
  margin-bottom:10px;
}

/* STATUS */
.status{
  padding:5px 10px;
  border-radius:10px;
  font-size:0.8rem;
  font-weight:600;
}

.status-pendente{background:#fff3cd;color:#856404;}
.status-preparando{background:#cce5ff;color:#004085;}
.status-entregue{background:#d4edda;color:#155724;}

/* TEXT */
.itens{font-size:0.9rem;color:#555;}
.total{font-weight:700;margin-top:10px;}

/* BUTTON */
.btn-avaliar{
  margin-top:10px;
  background:#ff5a1f;
  color:white;
  border:none;
  padding:8px 12px;
  border-radius:10px;
  font-size:0.9rem;
  cursor:pointer;
}

.btn-disabled{
  background:#ccc !important;
  cursor:not-allowed;
}

/* MODAL */
.modal-content{
  border-radius:16px;
  animation:fadeUp 0.3s ease;
}

/* ⭐ ESTRELAS */
.stars{
  display:flex;
  gap:5px;
  font-size:1.5rem;
  cursor:pointer;
}

.stars span{
  color:#ccc;
  transition:0.2s;
}

.stars span.active{
  color:#ff5a1f;
}

/* ANIMAÇÃO */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(20px);}
  to{opacity:1;transform:translateY(0);}
}
</style>
</head>

<body>

<%- include('partials/header') %>

<div class="content">

<div class="title">📦 Meus Pedidos</div>

<div class="grid">

<% pedidos.forEach(p => { %>

  <div class="card-pedido">

    <div class="card-header">
      <strong>#Pedido <%= p.id %></strong>

      <span class="status 
        <%= p.status === 'PENDENTE' ? 'status-pendente' : '' %>
        <%= p.status === 'PREPARANDO' ? 'status-preparando' : '' %>
        <%= p.status === 'ENTREGUE' ? 'status-entregue' : '' %>">
        <%= p.status %>
      </span>
    </div>

    <div class="itens">🍔 <%= p.itens %></div>
    <div class="total">💰 R$ <%= p.valor_total %></div>

    <% if (p.status === "ENTREGUE") { %>

      <% if (p.avaliado) { %>

        <button class="btn-avaliar btn-disabled" onclick="alertaAvaliado()" disabled>
          ✔ Já avaliado
        </button>

      <% } else { %>

        <button type="button"
          class="btn-avaliar"
          data-bs-toggle="modal"
          data-bs-target="#avaliar<%= p.id %>">
          ⭐ Avaliar
        </button>

      <% } %>

      <!-- MODAL -->
      <div class="modal fade" id="avaliar<%= p.id %>" tabindex="-1">
        <div class="modal-dialog">
          <div class="modal-content">

            <form action="/avaliacoes/avaliar" method="POST">

              <div class="modal-header">
                <h5>Avaliar Pedido</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
              </div>

              <div class="modal-body">

                <input type="hidden" name="pedido_id" value="<%= p.id %>">
                <input type="hidden" name="vendedor_id" value="<%= p.vendedor_id %>">
                <input type="hidden" name="nota" id="nota<%= p.id %>">

                <label>Nota</label>

                <div class="stars" data-id="<%= p.id %>">
                  <span data-value="1">★</span>
                  <span data-value="2">★</span>
                  <span data-value="3">★</span>
                  <span data-value="4">★</span>
                  <span data-value="5">★</span>
                </div>

                <textarea name="comentario" class="form-control mt-3" placeholder="Comentário"></textarea>

              </div>

              <div class="modal-footer">
                <button class="btn btn-success">Enviar</button>
              </div>

            </form>

          </div>
        </div>
      </div>

    <% } %>

  </div>

<% }) %>

</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<!-- ⭐ SCRIPT ESTRELAS -->
<script>
document.querySelectorAll(".stars").forEach(container => {
  const stars = container.querySelectorAll("span");
  const id = container.dataset.id;
  const input = document.getElementById("nota" + id);

  stars.forEach(star => {
    star.addEventListener("click", () => {
      const value = star.dataset.value;
      input.value = value;

      stars.forEach(s => s.classList.remove("active"));

      for(let i = 0; i < value; i++){
        stars[i].classList.add("active");
      }
    });
  });
});
</script>

<!-- ⚠️ ALERTA -->
<script>
function alertaAvaliado(){
  alert("Você já avaliou este pedido!");
}
</script>

</body>
</html>