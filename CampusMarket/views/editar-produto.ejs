<!DOCTYPE html>
<html>
<head>
  <title>Editar Produto</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="container mt-5">

  <h2>✏️ Editar Produto</h2>

  <form action="/dashboard/editar/<%= produto.id %>" method="POST">

    <input class="form-control mb-3" type="text" name="nome" value="<%= produto.nome %>" required>

    <input class="form-control mb-3" type="number" step="0.01" name="preco" value="<%= produto.preco %>" required>

    <input class="form-control mb-3" type="text" name="imagem_url" value="<%= produto.imagem_url %>">

    <textarea class="form-control mb-3" name="descricao"><%= produto.descricao %></textarea>

    <button class="btn btn-warning">Atualizar</button>

  </form>

</body>
</html>