<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Bem-vindo - CampusMarket</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Inter',sans-serif;}

body{
  height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  background:#ffffff;
}

/* CARD */
.card{
  text-align:center;
  background:#f8f8f8;
  padding:50px;
  border-radius:20px;
  box-shadow:0 20px 60px rgba(0,0,0,0.1);
  animation:fadeUp 1s ease;
}

.logo{
  font-size:1.8rem;
  font-weight:800;
  color:#ff5a1f;
}

.title{
  font-size:1.6rem;
  margin:20px 0;
  overflow:hidden;
  white-space:nowrap;
  border-right:3px solid #ff5a1f;
  width:0;
  animation:typing 2s steps(30) forwards, blink 0.7s infinite;
}

.sub{
  color:#555;
  margin-top:10px;
}

.loader{
  margin-top:20px;
  border:4px solid #eee;
  border-top:4px solid #ff5a1f;
  border-radius:50%;
  width:40px;
  height:40px;
  animation:spin 1s linear infinite;
}

/* ANIMAÇÕES */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(30px);}
  to{opacity:1;transform:translateY(0);}
}

@keyframes typing{
  to{width:100%;}
}

@keyframes blink{
  50%{border-color:transparent;}
}

@keyframes spin{
  to{transform:rotate(360deg);}
}
</style>
</head>

<body>

<div class="card">
  <div class="logo">CampusMarket</div>

  <div class="title">
    Bem-vindo! Aproveite as delícias do campus 🍔
  </div>

  <div class="sub">
    Você está entrando na melhor experiência de lanches do campus
  </div>

  <div class="loader"></div>
</div>

<script>
setTimeout(()=>{
  window.location.href = "/cliente";
}, 2500);
</script>

</body>
</html>