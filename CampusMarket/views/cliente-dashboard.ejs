<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>CampusMarket</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: #f5f5f5;
    }

    .header {
      background: #ea1d2c;
      color: white;
      padding: 15px;
      font-size: 20px;
      font-weight: bold;
    }

    .card-produto {
      border-radius: 15px;
      transition: 0.3s;
    }

    .card-produto:hover {
      transform: scale(1.03);
    }

    .btn-ifood {
      background: #ea1d2c;
      color: white;
      border: none;
    }

    .btn-ifood:hover {
      background: #c21825;
    }

    img {
      border-radius: 10px;
    }
  </style>
</head>

<body>

<div class="header">
  🍔 CampusMarket
</div>

<div class="container mt-4">

  <h4>Olá 👋</h4>
  <p>Escolha seu lanche</p>

  <div class="row">

    <% produtos.forEach(produto => { %>

      <div class="col-md-3 mb-4">

        <div class="card card-produto shadow-sm p-3">

          <img src="<%= produto.imagem_url %>" height="150" style="object-fit: cover;">

          <h5 class="mt-2"><%= produto.nome %></h5>

          <p class="text-muted"><%= produto.vendedor_nome %></p>

          <h6>R$ <%= produto.preco %></h6>

          <form action="/carrinho/add/<%= produto.id %>" method="POST">
            <button class="btn btn-ifood w-100 mt-2">
              🛒 Adicionar
            </button>
          </form>

        </div>

      </div>

    <% }) %>

  </div>

</div>

</body>
</html>