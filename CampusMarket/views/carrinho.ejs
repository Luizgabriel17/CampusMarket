<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Carrinho</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<div class="container mt-5">

  <h2>🛒 Seu Carrinho</h2>

  <table class="table mt-3">

    <tr>
      <th>Produto</th>
      <th>Preço</th>
      <th>Ação</th>
    </tr>

    <% let total = 0; %>

    <% carrinho.forEach((item, index) => { %>

      <% total += item.preco; %>

      <tr>
        <td><%= item.nome %></td>
        <td>R$ <%= item.preco %></td>
        <td>
          <a href="/carrinho/remove/<%= index %>" class="btn btn-danger btn-sm">
            Remover
          </a>
        </td>
      </tr>

    <% }) %>

  </table>

  <h4>Total: R$ <%= total %></h4>

  <form action="/pedido/finalizar" method="POST">
    <button class="btn btn-success mt-3">
      Finalizar Pedido
    </button>
  </form>

</div>

</body>
</html>