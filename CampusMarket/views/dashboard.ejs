<!DOCTYPE html>
<html>
<head>
  <title>Dashboard Vendedor</title>

  <link rel="stylesheet" href="/css/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<%- include('partials/header') %>

<div class="dashboard">

<h2>📊 Dashboard do Vendedor</h2>

<!-- CARDS -->
<div class="row mb-4">

  <div class="col-md-4">
    <div class="card-resumo bg-vendas">
      💰 Vendas Hoje <br>
      R$ <%= totalVendas || 0 %>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card-resumo bg-pedidos">
      📦 Pedidos <br>
      <%= totalPedidos || 0 %>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card-resumo bg-faturamento">
      💵 Faturamento <br>
      R$ <%= faturamento || 0 %>
    </div>
  </div>

</div>

<!-- PRODUTOS -->
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4>🍔 Meus Produtos</h4>
  <a href="/dashboard/produtos/novo" class="btn btn-success">+ Novo</a>
</div>

<div class="row">

<% produtos.forEach(p => { %>

  <div class="col-md-4 mb-3">
    <div class="card p-3 produto-card">

      <h5><%= p.nome %></h5>

      <p><%= p.descricao %></p>

      <p><strong>R$ <%= p.preco %></strong></p>

      <p>📦 Estoque: <%= p.estoque %></p>

      <div class="d-flex justify-content-between">

        <a href="/dashboard/produtos/editar/<%= p.id %>" class="btn btn-warning btn-sm">
          ✏️
        </a>

        <form action="/dashboard/produtos/deletar/<%= p.id %>" method="POST">
          <button class="btn btn-danger btn-sm">🗑️</button>
        </form>

      </div>

    </div>
  </div>

<% }) %>

</div>

<!-- PEDIDOS -->
<h4 class="mt-4">📦 Pedidos Recebidos</h4>

<% pedidos.forEach(p => { %>

  <div class="pedido-card">

    <strong>Pedido #<%= p.id %></strong><br>

    Itens: <%= p.itens %><br>

    Total: R$ <%= p.valor_total %><br>

    Status: <strong><%= p.status %></strong>

    <!-- ALTERAR STATUS -->
    <form action="/dashboard/pedidos/status/<%= p.id %>" method="POST" class="mt-2">

      <select name="status" class="form-control mb-2">
        <option>PENDENTE</option>
        <option>PREPARANDO</option>
        <option>SAIU</option>
        <option>ENTREGUE</option>
      </select>

      <button class="btn btn-primary btn-sm">
        Atualizar
      </button>

    </form>

  </div>

<% }) %>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<%- include('partials/footer') %>
</body>
</html>