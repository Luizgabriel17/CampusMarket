<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<nav class="navbar navbar-dark bg-dark">
  <div class="container">
    <span class="navbar-brand">Painel do Vendedor</span>
    <a href="/logout" class="btn btn-light">Sair</a>
  </div>
</nav>

<div class="container mt-4">
  <h3>Bem-vindo, vendedor! 🧑‍💼</h3>

  <div class="row mt-4">

    <div class="col-md-4">
      <div class="card p-3 shadow">
        <h5>📦 Produtos</h5>
        <p>Gerencie seus produtos</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card p-3 shadow">
        <h5>🛒 Pedidos</h5>
        <p>Veja os pedidos recebidos</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card p-3 shadow">
        <h5>📊 Relatórios</h5>
        <p>Veja seu desempenho</p>
      </div>
    </div>

  </div>
</div>

</body>
</html>