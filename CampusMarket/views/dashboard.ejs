<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<nav class="navbar navbar-dark bg-dark">
  <div class="container">
    <span class="navbar-brand">CampusMarket - Vendedor</span>
    <div>
      <span class="text-white me-3">
        Olá, <%= typeof user !== 'undefined' && user ? user.nome : "Vendedor" %>
      </span>
      <a href="/logout" class="btn btn-light">Sair</a>
    </div>
  </div>
</nav>

<div class="container mt-4">

  <h3>Painel do Vendedor 🧑‍💼</h3>

  <!-- BOTÃO NOVO PRODUTO -->
  <a href="/dashboard/produtos/novo" class="btn btn-success mb-3">
    ➕ Novo Produto
  </a>

  <!-- TABELA DE PRODUTOS -->
  <table class="table table-bordered">
    <thead class="table-dark">
      <tr>
        <th>Nome</th>
        <th>Preço</th>
        <th>Estoque</th>
        <th>Ações</th>
      </tr>
    </thead>

    <tbody>
      <% if (produtos && produtos.length > 0) { %>
        <% produtos.forEach(p => { %>
          <tr>
            <td><%= p.nome %></td>
            <td>R$ <%= p.preco %></td>
            <td><%= p.estoque %></td>
            <td>

              <!-- EDITAR -->
              <a href="/dashboard/produtos/editar/<%= p.id %>" class="btn btn-warning btn-sm">
                ✏️ Editar
              </a>

              <!-- DELETAR -->
              <form action="/dashboard/produtos/deletar/<%= p.id %>" method="POST" style="display:inline;">
                <button class="btn btn-danger btn-sm">
                  🗑️ Excluir
                </button>
              </form>

            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="4" class="text-center">Nenhum produto cadastrado</td>
        </tr>
      <% } %>
    </tbody>

  </table>

</div>

</body>
</html>