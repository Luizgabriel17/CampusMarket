<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Dashboard Vendedor</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background-color: #f5f5f5;
    }

    .sidebar {
      height: 100vh;
      background-color: #ea1d2c;
      color: white;
      padding: 20px;
    }

    .sidebar h2 {
      font-weight: bold;
    }

    .sidebar a {
      color: white;
      display: block;
      margin: 15px 0;
      text-decoration: none;
    }

    .sidebar a:hover {
      text-decoration: underline;
    }

    .card-dashboard {
      border-radius: 15px;
      padding: 20px;
      color: white;
    }

    .card-red { background-color: #ea1d2c; }
    .card-dark { background-color: #333; }
    .card-green { background-color: #28a745; }

    .table-container {
      background: white;
      padding: 20px;
      border-radius: 15px;
      margin-top: 20px;
    }

    .btn-ifood {
      background-color: #ea1d2c;
      color: white;
      border: none;
    }

    .btn-ifood:hover {
      background-color: #c21825;
    }

    img {
      border-radius: 10px;
    }
  </style>
</head>

<body>

<div class="container-fluid">
  <div class="row">

    <!-- SIDEBAR -->
    <div class="col-md-2 sidebar">
      <h2>🍔 Vendedor</h2>
      <a href="/dashboard">Dashboard</a>
      <a href="/dashboard/novo">Cadastrar Produto</a>
    </div>

    <!-- CONTEÚDO -->
    <div class="col-md-10 p-4">

      <h3>📊 Painel do Vendedor</h3>

      <!-- CARDS -->
      <div class="row mt-4">

        <div class="col-md-4">
          <div class="card-dashboard card-red">
            <h5>Total de Produtos</h5>
            <h2><%= produtos.length %></h2>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card-dashboard card-dark">
            <h5>Pedidos</h5>
            <h2>--</h2>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card-dashboard card-green">
            <h5>Faturamento</h5>
            <h2>R$ --</h2>
          </div>
        </div>

      </div>

      <!-- BOTÃO -->
      <div class="mt-4">
        <a href="/dashboard/novo" class="btn btn-ifood">+ Novo Produto</a>
      </div>

      <!-- TABELA -->
      <div class="table-container">

        <h4>📦 Seus Produtos</h4>

        <table class="table table-hover mt-3">
          <thead>
            <tr>
              <th>Imagem</th>
              <th>Nome</th>
              <th>Preço</th>
              <th>Status</th>
              <th>Ações</th>
            </tr>
          </thead>

          <tbody>
            <% produtos.forEach(produto => { %>
              <tr>
                <td>
                  <img src="<%= produto.imagem_url %>" width="60">
                </td>

                <td><%= produto.nome %></td>
                <td>R$ <%= produto.preco %></td>
                <td>
                  <span class="badge bg-success"><%= produto.status %></span>
                </td>

                <td>
                  <a href="/dashboard/editar/<%= produto.id %>" class="btn btn-sm btn-warning">Editar</a>

                  <form action="/dashboard/deletar/<%= produto.id %>" method="POST" style="display:inline;">
                    <button class="btn btn-sm btn-danger">Excluir</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>

        </table>

      </div>

    </div>
  </div>
</div>

</body>
</html>