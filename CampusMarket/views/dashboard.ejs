<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Dashboard Vendedor - CampusMarket</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Inter',sans-serif;}

body{
  background:#ffffff;
  display:flex;
}

/* SIDEBAR */
.sidebar{
  width:220px;
  height:100vh;
  background:#f8f8f8;
  padding:20px;
  position:fixed;
}

/* CONTENT */
.dashboard{
  margin-left:240px;
  padding:30px;
  width:100%;
}

/* TITLE */
.title{
  font-size:1.8rem;
  font-weight:800;
  margin-bottom:20px;
}

/* RESUMO CARDS */
.resumo-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:20px;
  margin-bottom:30px;
}

.card-resumo{
  padding:20px;
  border-radius:16px;
  color:white;
  font-weight:600;
  font-size:1.1rem;
  box-shadow:0 10px 30px rgba(0,0,0,0.1);
  animation:fadeUp 0.6s ease;
}

.bg-vendas{background:#ff5a1f;}
.bg-pedidos{background:#ff8c42;}
.bg-faturamento{background:#ffb347;}

/* PRODUTOS */
.produtos-header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:15px;
}

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(250px,1fr));
  gap:20px;
}

/* CARD PRODUTO */
.produto-card{
  background:#fff;
  padding:20px;
  border-radius:16px;
  box-shadow:0 10px 30px rgba(0,0,0,0.08);
  transition:.3s;
  animation:fadeUp 0.6s ease;
}

.produto-card:hover{
  transform:translateY(-5px);
}

/* BOTÕES */
.btn-sm{
  border-radius:8px;
}

/* PEDIDOS */
.pedido-card{
  margin-top:15px;
  padding:20px;
  border-radius:16px;
  background:#fff;
  box-shadow:0 10px 30px rgba(0,0,0,0.08);
  animation:fadeUp 0.6s ease;
}

/* STATUS */
.status{
  padding:5px 10px;
  border-radius:10px;
  font-size:0.8rem;
  font-weight:600;
}

.status-pendente{background:#fff3cd;color:#856404;}
.status-preparando{background:#cce5ff;color:#004085;}
.status-saiu{background:#e2e3ff;color:#383d7c;}
.status-entregue{background:#d4edda;color:#155724;}

/* ANIMAÇÃO */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(20px);}
  to{opacity:1;transform:translateY(0);}
}
</style>
</head>

<body>

<%- include('partials/header') %>

<div class="dashboard">

<div class="title">📊 Dashboard do Vendedor</div>

<!-- RESUMO -->
<div class="resumo-grid">

  <div class="card-resumo bg-vendas">
    💰 Vendas Hoje <br>
    R$ <%= totalVendas || 0 %>
  </div>

  <div class="card-resumo bg-pedidos">
    📦 Pedidos <br>
    <%= totalPedidos || 0 %>
  </div>

  <div class="card-resumo bg-faturamento">
    💵 Faturamento <br>
    R$ <%= faturamento || 0 %>
  </div>

</div>

<!-- PRODUTOS -->
<div class="produtos-header">
  <h4>🍔 Meus Produtos</h4>
  <a href="/dashboard/produtos/novo" class="btn btn-success">+ Novo</a>
</div>

<div class="grid">

<% produtos.forEach(p => { %>

  <div class="produto-card">

    <h5><%= p.nome %></h5>

    <p><%= p.descricao %></p>

    <p><strong>R$ <%= p.preco %></strong></p>

    <p>📦 Estoque: <%= p.estoque %></p>

    <div class="d-flex justify-content-between">

      <a href="/dashboard/produtos/editar/<%= p.id %>" class="btn btn-warning btn-sm">
        ✏️
      </a>

      <form action="/dashboard/produtos/deletar/<%= p.id %>" method="POST">
        <button class="btn btn-danger btn-sm">🗑️</button>
      </form>

    </div>

  </div>

<% }) %>

</div>

<!-- PEDIDOS -->
<h4 class="mt-4">📦 Pedidos Recebidos</h4>

<% pedidos.forEach(p => { %>

  <div class="pedido-card">

    <strong>#Pedido <%= p.id %></strong><br>

    <p>🍔 <%= p.itens %></p>

    <p>💰 R$ <%= p.valor_total %></p>

    <span class="status 
      <%= p.status === 'PENDENTE' ? 'status-pendente' : '' %>
      <%= p.status === 'PREPARANDO' ? 'status-preparando' : '' %>
      <%= p.status === 'SAIU' ? 'status-saiu' : '' %>
      <%= p.status === 'ENTREGUE' ? 'status-entregue' : '' %>">
      <%= p.status %>
    </span>

    <form action="/dashboard/pedidos/status/<%= p.id %>" method="POST" class="mt-2">

      <select name="status" class="form-control mb-2">
        <option>PENDENTE</option>
        <option>PREPARANDO</option>
        <option>SAIU</option>
        <option>ENTREGUE</option>
      </select>

      <button class="btn btn-primary btn-sm">
        Atualizar
      </button>

    </form>

  </div>

<% }) %>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<%- include('partials/footer') %>

</body>
</html>